gogogo()
{
	local dest num=0
	
	Lance lancement: true # Une premiÃĻre tÃĒche nommÃĐe "lancement" pour que celles lancÃĐes dans notre boucle puissent faire un Apres lancement~ sans message d'erreur "je suis la premiÃĻre de la lignÃĐe, donc il n'y en a aucune de ce nom".
	

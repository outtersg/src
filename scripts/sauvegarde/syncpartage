joindreEtPlanifier()
{
	local num=$1 dest="$2" h="`echo "$2" | sed -e 's#.*://##' -e 's#/.*##'`"
	local file joignable=$(ssh -o ConnectTimeout=5 "$h" sh -c 'ps auxww | grep "[u]nison" | wc -l' | tr -d ' \t')
	case "$joignable" in
		"") return 0 ;;
		0) true ;;
		*) sleep 1 ;; # Une faÃ§on de temporiser le lancement si un unison tourne dÃĐjÃ . En rÃĐalitÃĐ on temporise l'empilement via AprÃĻs, ce qui nous empilera aprÃĻs tous ceux dÃĐjÃ  empilÃĐs sous ce nom (et la seconde supplÃĐmentaire laisse un peu plus de temps pour dÃĐtecter d'autres qui peuvent ÃŠtre lancÃĐs immÃĐdiatement).
	esac
	echo "$h joignable, $joignable unison tournant dÃĐjÃ  dessus"
	Apres lancement~ lancement: faire "$h" "$dest"
}

faire()
{
	local dest="$2"
	echo "Je fais $1"
	lockf -t 10 $HOME/tmp/partage.verrou $HOME/local/bin/unison -batch -backups -maxbackups 3 $source $dest
}

case `uname` in
	Linux)
		lockf()
		{
			case "$1" in -t) shift ; set -- -w "$@" ;; esac
			flock "$@"
		}
		;;
	Darwin)
		# Ã FAIRE: si on a un truc compilÃĐ dans les parages, l'utiliser.
		lockf() { lockf_logiciel "$@" ; }
		;;
esac

lockf_logiciel()
{
	local attente=
	case "$1" in -t) shift ; attente="$1" ; shift ;; esac
	local verrou="$1" ; shift
	while [ -f "$verrou" ]
	do
		case "$attente" in
			0) echo "lockf: $verrou: already locked" >&2 ; return 75 ;; # Erreur calquÃĐe sur celle d'un FreeBSD 15.
			"") true ;;
			*[^0-9]*) echo "# Le temps d'attente du verrou doit ÃŠtre un nombre ($attente)." >&2 ; return 1 ;;
			[0-9]*) attente=$((attente - 1)) ;;
		esac
		sleep 1
	done
	menage_lockf_logiciel() { rm -f "$verrou" ; }
	trap menage_lockf_logiciel EXIT
	touch "$verrou"
	"$@"
	menage_lockf_logiciel
}

tourner "$@"
